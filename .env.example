## Copy this file to .env.local and replace placeholder values.
## Never commit real secrets.

# Core app
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Mail delivery
CONTACT_SMTP_HOST=mail.stylingbyva.com
CONTACT_SMTP_PORT=465
CONTACT_SMTP_SECURE=true
CONTACT_SMTP_USER=sales@stylingbyva.com
CONTACT_SMTP_PASSWORD=your-mailbox-password
CONTACT_FROM_EMAIL=sales@stylingbyva.com
CONTACT_TO_EMAIL=sales@stylingbyva.com
CREATOR_PROGRAM_FROM_EMAIL=no-reply@stylingbyva.com
CREATOR_PROGRAM_TO_EMAIL=sales@stylingbyva.com

# Optional SMTP password aliases used as fallbacks in code
# SMTP_PASSWORD=your-mailbox-password
# MAIL_PASSWORD=your-mailbox-password
# EMAIL_PASSWORD=your-mailbox-password

# App security and URLs
CONTACT_CAPTCHA_SECRET=optional-extra-secret-for-captcha-signing
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Carrier integrations (keep only if you use these providers)
SPEEDY_USERNAME=your-speedy-username
SPEEDY_PASSWORD=your-speedy-password
ECONT_USERNAME=your-econt-username-or-email
ECONT_PASSWORD=your-econt-password
ECONT_BASE_URL=https://ee.econt.com/services/